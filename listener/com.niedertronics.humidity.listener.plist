<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>            <string>com.niedertronics.humidity.listener</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PYTHON__</string>
    <string>__HOME__/code/humidity-node/listener/humidity_listener.py</string>
  </array>
  <key>RunAtLoad</key>        <true/>
  <key>KeepAlive</key>        <true/>
  <key>StandardOutPath</key>  <string>__HOME__/Library/Logs/humidity-listener.out.log</string>
  <key>StandardErrorPath</key><string>__HOME__/Library/Logs/humidity-listener.err.log</string>
</dict>
</plist>
